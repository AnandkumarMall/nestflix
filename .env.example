# Copy this file to ".env" and fill in your values.

# Your TMDB API key (v3 auth). Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# One or more folders containing your movies / TV shows.
# On Windows, separate multiple paths with a semicolon.
# Use forward slashes or escaped backslashes.
LIBRARY_PATHS=D:/Movies;D:/TV Shows

# Port the app serves on (UI + API).
PORT=8000

# Some ISPs DNS-poison TMDB (requests time out). Leave "true" to resolve TMDB
# hostnames via Cloudflare DNS-over-HTTPS (1.1.1.1). Set "false" if your network is fine.
TMDB_USE_DOH=true
